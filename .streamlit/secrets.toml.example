# Copy this file to .streamlit/secrets.toml and fill in your real values.
# secrets.toml is gitignored — never commit it.
#
# On Streamlit Community Cloud, paste these values into:
#   App dashboard → Settings → Secrets
#
# Leave blank (or omit this file entirely) to use the local JSON fallback
# during development.

SUPABASE_URL = "https://your-project-ref.supabase.co"
SUPABASE_KEY = "your-service-role-key"
